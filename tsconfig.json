{
  "compilerOptions": {
    "moduleResolution":"nodenext",
    "module": "NodeNext",
    "target": "ESNext",
    "outDir": "./dst",
    "baseUrl": "./src",
    "strict": true,
    "removeComments": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["./src"]
}
